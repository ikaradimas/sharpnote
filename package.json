{
  "name": "polyglot-clone",
  "version": "1.0.0",
  "description": "Polyglot Notebook - Electron desktop app for Markdown + C# notebooks",
  "main": "main.js",
  "scripts": {
    "build:renderer": "esbuild src/renderer.jsx --bundle --outfile=dist/renderer.js --loader:.jsx=jsx",
    "start": "npm run build:renderer && electron .",
    "dev": "npm run build:renderer && electron ."
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/legacy-modes": "^6.5.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.3",
    "chart.js": "^4.4.8",
    "codemirror": "^6.0.1",
    "marked": "^15.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.1",
    "electron": "^34.3.1"
  }
}
